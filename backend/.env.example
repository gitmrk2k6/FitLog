# データベース接続（docker compose の PostgreSQL）
DATABASE_URL=postgresql+psycopg://fitlog:fitlog@localhost:5432/fitlog
# pytest 用テストDB（同一 PostgreSQL 上の別データベース）
TEST_DATABASE_URL=postgresql+psycopg://fitlog:fitlog@localhost:5432/fitlog_test

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ストレージ（F-10 用。現状 local のみ実装）
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./var/uploads

# CORS（フロントエンド）
FRONTEND_ORIGIN=http://localhost:3000
